# Copy to `.env` in the repository root for docker compose variable substitution.

MONGODB_URI=mongodb://mongodb:27017
MONGODB_DB_NAME=yelp_db
SECRET_KEY=replace-with-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Host ports mapped from containers (defaults match Lab 2 compose file)
MONGO_HOST_PORT=27017
USER_SERVICE_PORT=8001
OWNER_SERVICE_PORT=8002
RESTAURANT_SERVICE_PORT=8003
REVIEW_SERVICE_PORT=8004
FRONTEND_PORT=3000

# Frontend Docker build (Vite). Passed as build-arg from docker-compose.
# Leave empty for same-origin API calls (nginx in the frontend container proxies to backends).
# Set to a full origin only if the browser must call APIs elsewhere (e.g. external gateway).
VITE_API_BASE_URL=
# Optional alias for the same value (if your team uses this name instead):
# FRONTEND_API_BASE_URL=

# AI (restaurant-service)
GEMINI_API_KEY=
TAVILY_API_KEY=
