# Copy to `.env` in the repository root for docker compose variable substitution.

MONGODB_URI=mongodb://mongodb:27017
MONGODB_DB_NAME=yelp_db
SECRET_KEY=replace-with-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Host ports mapped from containers (defaults match Lab 2 compose file)
MONGO_HOST_PORT=27017
USER_SERVICE_PORT=8001
OWNER_SERVICE_PORT=8002
RESTAURANT_SERVICE_PORT=8003
REVIEW_SERVICE_PORT=8004
FRONTEND_PORT=3000

# AI (restaurant-service)
GEMINI_API_KEY=
TAVILY_API_KEY=
