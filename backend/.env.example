# Copy to backend/.env and adjust. Used by local uvicorn and docker-compose.

# MongoDB (Lab 2 runtime)
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB_NAME=yelp_db

# MySQL — only needed for scripts/migrate_mysql_to_mongo.py (Lab 1 source DB)
DATABASE_URL=mysql+pymysql://yelp:yelppass@127.0.0.1:3306/yelp_db

SECRET_KEY=replace-with-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AI assistant (restaurant service)
GEMINI_API_KEY=
TAVILY_API_KEY=

# Legacy README name — not read by ai_service (uses GEMINI_API_KEY)
GOOGLE_API_KEY=
