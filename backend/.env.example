# Copy to backend/.env and adjust. Used by local uvicorn and docker-compose.
#
# When running the full stack with `docker compose` from the repo root, prefer the
# root `.env.example` (service hostnames like `mongodb` apply inside the network).

# MongoDB (Lab 2 runtime)
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB_NAME=yelp_db

# MySQL — only for scripts/migrate_mysql_to_mongo.py (Lab 1 source DB).
# If MySQL runs in Docker with host port 3307, use :3307 not :3306.
# DATABASE_URL=mysql+pymysql://yelp:yelppass@127.0.0.1:3307/yelp_db
# Or: MYSQL_HOST=127.0.0.1 MYSQL_PORT=3307 MYSQL_USER=yelp MYSQL_PASSWORD=... MYSQL_DATABASE=yelp_db
DATABASE_URL=mysql+pymysql://yelp:yelppass@127.0.0.1:3306/yelp_db

SECRET_KEY=replace-with-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AI assistant (restaurant service)
GEMINI_API_KEY=
TAVILY_API_KEY=

# Legacy README name — not read by ai_service (uses GEMINI_API_KEY)
GOOGLE_API_KEY=
