# Copy to frontend/.env for local overrides (Vite reads VITE_* only).

# Leave empty to call the API on the same origin (recommended):
# - `npm run dev`: Vite proxies path prefixes to microservices (see vite.config.js).
# - Docker: nginx in the frontend container proxies to user/owner/restaurant/review services.
#
# Set only if the API is on another origin (e.g. hosted gateway):
# VITE_API_BASE_URL=https://api.example.com

VITE_API_BASE_URL=
